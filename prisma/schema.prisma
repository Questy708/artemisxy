// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Donation {
  id              String   @id @default(cuid())
  donorEmail      String
  donorName       String?
  donorAnonymous  Boolean  @default(false)
  amount          Float
  currency        String   @default("USD")
  paymentMethod   String   @default("card")
  paymentStatus   String   @default("pending")
  transactionRef  String   @unique
  stripeSessionId String?
  perkId          String?
  isRecurring     Boolean  @default(false)
  recurringFreq   String?
  message         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Application {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String
  email             String
  phone             String?
  birthdate         String?
  gender            String?
  pronoun           String?
  citizenship       String?
  dualCitizenship   String?
  address           String?
  city              String?
  state             String?
  postalCode        String?
  country           String?
  howHeard          String?
  applicationCycle  String?
  concentration     String?
  currentlyEnrolled String?
  schoolName        String?
  schoolCountry     String?
  schoolCity        String?
  enrollmentStart   String?
  enrollmentEnd     String?
  gradingScale      String?
  gpa               String?
  maxGpa            String?
  satMath           String?
  satReading        String?
  actScore          String?
  isTestOptional    Boolean  @default(false)
  accomplishments   String?  // JSON string
  personalStatement String?
  missionStatement  String?
  applyingForAid    String?
  householdIncome   String?
  dependents        String?
  status            String   @default("submitted")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  area      String?  // e.g. "General Enquiry", "Donations", "Partnerships"
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?  // e.g. "blog", "homepage", "footer"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
