# Database
DATABASE_URL=file:/home/z/my-project/db/custom.db

# Admin dashboard password — REQUIRED before deploying!
# Set this to a strong, unique password. Anyone with this password can view all form data.
ADMIN_PASSWORD=change_me_to_a_strong_password

# ═══════════════════════════════════════════════════
# PAYMENT GATEWAY — Pick ONE option:
# ═══════════════════════════════════════════════════

# Option A: Stripe (requires EIN / business registration)
# Get your keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Option B: Simple payment link — NO business docs needed!
# Just create an account on one of these and paste your link:
#   - PayPal: https://paypal.me/yourname
#   - Buy Me a Coffee: https://buymeacoffee.com/yourname
#   - Ko-fi: https://ko-fi.com/yourname
# The form will redirect donors there to complete payment.
DONATION_LINK=https://paypal.me/yourname

# Base URL for your site (needed for payment redirects)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
