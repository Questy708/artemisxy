# Database
DATABASE_URL=file:/home/z/my-project/db/custom.db

# Admin dashboard password — REQUIRED before deploying!
# Set this to a strong, unique password. Anyone with this password can view all form data.
ADMIN_PASSWORD=change_me_to_a_strong_password

# Stripe Payment Gateway (optional - donations work without it, just marked as "pending")
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe Webhook Secret (needed to auto-update payment status)
# Set up webhook at https://dashboard.stripe.com/webhooks pointing to /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Base URL for Stripe checkout redirects and webhook return URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
